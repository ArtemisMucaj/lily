#!/usr/bin/env bash
# up — build the lily template image, load it into Docker Sandboxes, and run
# the stack: everything in sandbox/README.md's setup in one command.
#
#   sandbox/up ~/code/my-project [more-projects...]      # run (template loaded)
#   sandbox/up --build ~/code/my-project                 # rebuild + load first
#
# Project folders are mounted at their host absolute paths (append :ro for
# read-only); ~/.lily is always mounted so state and config are shared with
# the host. Resume an existing sandbox instead with:
#
#   sbx run --kit sandbox/kit <sandbox-name>
set -euo pipefail

log() { printf '[lily] %s\n' "$*"; }
die() {
    log "ERROR: $*" >&2
    exit 1
}

ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"

usage() { printf 'usage: sandbox/up [--build] PROJECT_DIR[:ro] [PROJECT_DIR[:ro]...]\n'; }

build=0
projects=()
while [ $# -gt 0 ]; do
    case "$1" in
        --build) build=1 ;;
        -h | --help)
            usage
            exit 0
            ;;
        --) # everything after -- is a project path, dashes and all
            shift
            projects+=("$@")
            break
            ;;
        -*)
            usage >&2
            die "unknown option: $1"
            ;;
        *) projects+=("$1") ;;
    esac
    shift
done
if [ ${#projects[@]} -eq 0 ]; then
    usage >&2
    exit 1
fi

command -v docker >/dev/null || die "docker not found"
command -v sbx >/dev/null || die "sbx not found (Docker Sandboxes CLI)"

for p in "${projects[@]}"; do
    [ -d "${p%:ro}" ] || die "project directory not found: ${p%:ro}"
done

if [ "$build" = 1 ]; then
    log "building lily:latest from $ROOT"
    docker build -f "$ROOT/sandbox/Dockerfile" -t lily:latest "$ROOT"
    tmp="$(mktemp -d)"
    trap 'rm -rf "$tmp"' EXIT
    log "loading the image into Docker Sandboxes"
    docker image save lily:latest -o "$tmp/lily.tar"
    sbx template load "$tmp/lily.tar"
fi

mkdir -p "$HOME/.lily"
log "starting the lily sandbox"
exec sbx run --kit "$ROOT/sandbox/kit" lily "${projects[@]}" "$HOME/.lily"
