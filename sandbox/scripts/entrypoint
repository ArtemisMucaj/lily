#!/usr/bin/env bash
# entrypoint — agent entrypoint for the lily Docker Sandbox kit, run whenever
# the sandbox's agent session starts (sbx run / resume).
#
# Boots the full lily experience inside one sandbox microVM:
#   1. a locked-down Tuwunel Matrix homeserver (no federation, registration
#      token-gated)                                          — lib/matrix.sh
#   2. opencode serve on 127.0.0.1:4096, behind an auth gate so the operator
#      can run `opencode auth login` first                   — lib/opencode.sh
#   3. an optional ngrok tunnel (only when NGROK_AUTHTOKEN is set)
#                                                            — lib/ngrok.sh
#   4. lily itself, allowlisted to the owner account only
#
# This file is only the boot order; the steps live in lib/*.sh. Every
# service — lily included — is supervised (lib/supervise.sh): if it crashes
# it is restarted with exponential backoff.
#
# Host-side settings are read from ~/.lily/sandbox/config.env (the .lily
# workspace is shared with the host, so edit that file on either side).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
for lib in "$SCRIPT_DIR"/lib/*.sh; do
    # shellcheck disable=SC1090
    . "$lib"
done

load_config

cleanup() {
    trap - EXIT INT TERM
    log "shutting down"
    jobs -pr | xargs -r kill 2>/dev/null || true
    wait 2>/dev/null || true
}
trap cleanup EXIT
trap 'cleanup; exit 130' INT
trap 'cleanup; exit 143' TERM

# Reconnecting to an existing sandbox reruns this entrypoint, so each start_*
# step is skipped when the service already answers.
start_matrix
ensure_matrix_accounts
start_opencode
start_ngrok
write_shell_env
print_banner

# lily's output stays attached to the agent session; the supervisor runs as a
# waited-on background child (not foreground) so TERM/INT interrupt the
# `wait` and the cleanup trap fires immediately instead of after lily exits.
log "starting lily"
supervise lily "$LOG_DIR/lily.log" lily run &
wait $!
