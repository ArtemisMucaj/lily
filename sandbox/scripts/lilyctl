#!/usr/bin/env bash
# lilyctl — run the lily CLI inside the sandbox with the same environment the
# running stack uses (data dir, opencode URL). Use from `sbx exec`:
#
#   sbx exec -it <sandbox-name> lilyctl project list
set -euo pipefail

env_file="$HOME/.lily-sandbox-env"
if [ -f "$env_file" ]; then
    # shellcheck disable=SC1090
    . "$env_file"
fi
exec lily "$@"
